# ── Exchange (BTC/ETH spot) ───────────────────────────────────────────────────
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_binance_key         # optional for public OHLCV only
EXCHANGE_API_SECRET=your_binance_secret
EXCHANGE_SANDBOX=true                     # always start on testnet

# ── LLM (debate engine) ───────────────────────────────────────────────────────
LLM_PROVIDER=none                         # "none" (heuristic, no LLM needed) | "ollama" (free local) | "openai" (paid)
# Ollama local setup (recommended): set LLM_PROVIDER=ollama, then pull the model once:
#   ollama run qwen3.5:9b-nvfp4
LLM_MODEL=qwen3.5:9b-nvfp4              # orama stack default; ignored when LLM_PROVIDER=none
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=                           # only if LLM_PROVIDER=openai

# ── Polymarket ────────────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0x...              # your Polygon wallet private key
POLYMARKET_PROXY_ADDRESS=0x...           # your Polymarket proxy/funder address
POLYMARKET_CHAIN_ID=137
PAPER_MODE=true                           # ALWAYS start here
BANKROLL_USDC=100.0
KELLY_FRACTION=0.25
MIN_EDGE_PCT=8.0
MAX_CONCURRENT_TRADES=3
DAILY_DRAWDOWN_LIMIT_PCT=5.0

# ── Spot trading risk ─────────────────────────────────────────────────────────
MAX_POSITION_SIZE_PCT=25.0
MAX_DRAWDOWN_PCT=10.0
RISK_PER_TRADE_PCT=1.0
MIN_CONFIDENCE_THRESHOLD=0.3

# ── Alerts ────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALPHA_VANTAGE_API_KEY=                    # optional: supplementary VIX data

# ── Storage / Logs ────────────────────────────────────────────────────────────
DB_PATH=data/trades.db
LOG_LEVEL=INFO

# ── FreqTrade (OPTIONAL execution sidecar — auto-detected, never required) ────
# auto = use only if already installed & API reachable; off = never; on = require
FREQTRADE_MODE=auto
FREQTRADE_URL=http://localhost:8080
FREQTRADE_USERNAME=superbot
FREQTRADE_PASSWORD=superbot_password
FREQTRADE_MCP_ENABLED=false
FREQTRADE_MCP_URL=http://localhost:8765
